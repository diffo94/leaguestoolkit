# Copy this file to .env.local and fill in your Worker's URL.
# .env.local is gitignored by default in Vite projects.

# Local dev (run `npm run dev` in worker/ first):
# VITE_WORKER_URL=http://localhost:8787

# Production (after `npx wrangler deploy` in worker/):
# VITE_WORKER_URL=https://leaguestoolkit-api.YOUR-CF-SUBDOMAIN.workers.dev
#
# Recommendation for leaguestoolkit.com: bind the Worker to a subdomain
# (e.g. api.leaguestoolkit.com) via Cloudflare dashboard → Workers → Triggers →
# Custom Domains, then set:
# VITE_WORKER_URL=https://api.leaguestoolkit.com
